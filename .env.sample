# ──────────────────────────────────────────────────────────────────────────────
# Environment variables
#
# ALL of these are OPTIONAL. The site builds and runs without them — the blog
# (powered by Sanity) simply renders empty states until credentials are present.
# Copy this file to `.env` and fill in the values to enable the blog/CMS.
#
#   cp .env.sample .env
#
# Sanity setup guide:
#   https://github.com/vercel/next.js/tree/canary/examples/cms-sanity
# ──────────────────────────────────────────────────────────────────────────────

# Sanity project id (e.g. "abc12xyz"). Found in your Sanity project settings.
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Sanity dataset name (commonly "production").
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API version (date string, e.g. "2024-10-01").
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Server-only read token for draft/preview content. Create one under
# Sanity → API → Tokens (Viewer permission is enough for published content).
SANITY_API_READ_TOKEN=

# Origin used by the Studio's Presentation/preview tool (e.g. http://localhost:3000).
NEXT_PUBLIC_SANITY_STUDIO_PREVIEW_ORIGIN=http://localhost:3000

# Base URL for the contact-form API client (src/utils/axios.ts). Optional.
NEXT_PUBLIC_API_URL=

# ──────────────────────────────────────────────────────────────────────────────
# Speaking page: talks store, media, and admin auth (all OPTIONAL).
# Without these, /speaking renders the committed seed (data/talks.seed.json) and
# the admin is read-only. Provision Upstash + Blob via the Vercel Marketplace.
# ──────────────────────────────────────────────────────────────────────────────

# Upstash Redis (Vercel Marketplace). KV_REST_API_URL/TOKEN also accepted.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob store (for uploaded talk/showcase images).
BLOB_READ_WRITE_TOKEN=

# Admin sign-in: the password you log in with, and a long random signing secret.
# Generate a secret with:  openssl rand -base64 32
ADMIN_PASSWORD=
AUTH_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# Email alerts (OPTIONAL): notify on admin sign-in + brute-force lockout via Resend.
# Without RESEND_API_KEY, alerts no-op. Brute-force rate limiting uses the Upstash
# Redis above (also no-ops without it).
# ──────────────────────────────────────────────────────────────────────────────

# Resend API key (https://resend.com/api-keys).
RESEND_API_KEY=
# From address. Use a verified domain (e.g. "Alpha <noreply@alpharomer.com>").
# Falls back to "Alpha Admin <onboarding@resend.dev>" (Resend test sender).
RESEND_FROM=
# Where alerts are sent. Falls back to alpharomercoma@proton.me.
ALERT_EMAIL=

# ──────────────────────────────────────────────────────────────────────────────
# Mistral AI (OPTIONAL): powers the admin's "Draft from slides" button, which
# reads a Google Slides deck and autofills a talk's title, abstract, outline,
# key takeaways, and tags. Without it, the button is disabled. Get a key at
# https://console.mistral.ai/api-keys
# ──────────────────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=
